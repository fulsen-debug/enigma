# Required for scanner + paper agent web app
ENIGMA_JWT_SECRET=change_me_in_production
HELIUS_API_KEY=
HELIUS_API_KEYS=
# Or set SOLANA_RPC_URL directly instead of HELIUS_API_KEY
SOLANA_RPC_URL=https://your-rpc.example
SOLANA_RPC_FALLBACK_URLS=https://api.mainnet-beta.solana.com

# Optional providers / market data
JUPITER_API_KEY=
ENIGMA_RPC_RETRY_ATTEMPTS=3
ENIGMA_RPC_TIMEOUT_MS=12000
ENIGMA_ONCHAIN_CACHE_TTL_SEC=60

# Holder analysis
# First release should stay on sample mode for speed and consistency.
# Deep/full remain backend options but are not part of the recommended public flow.
ENIGMA_HOLDER_ANALYSIS_MODE=sample
ENIGMA_HOLDER_SIGNATURE_SAMPLE=25
ENIGMA_HOLDER_SIGNATURE_DEEP=240
ENIGMA_HOLDER_SIGNATURE_FULL=5000
ENIGMA_HOLDER_BUYSELL_SIGNATURE_SAMPLE=8
ENIGMA_HOLDER_BUYSELL_SIGNATURE_DEEP=60
ENIGMA_HOLDER_BUYSELL_SIGNATURE_FULL=5000
ENIGMA_HOLDER_BUYSELL_HOLDER_SAMPLE=5
ENIGMA_HOLDER_BUYSELL_HOLDER_DEEP=12
# Optional known wallet labels for holder tagging
# Example: ENIGMA_WALLET_LABELS=Addr1:okx,Addr2:binance,Addr3:phantom
ENIGMA_WALLET_LABELS=

# Storage
ENIGMA_STORAGE=local
ENIGMA_DB_PATH=./enigma_data.sqlite

# App behavior
ENIGMA_LOG_LEVEL=info
ENIGMA_CONFIRM_RISKY_ACTIONS=true
ENIGMA_PREMIUM_TELEGRAM=@AIGUARDIAN_SUPPORT
ENIGMA_ADMIN_TOKEN=
ENIGMA_PREMIUM_SOL_ADDRESS=ZEe2kStwjE8SNs61Vcrdmn63JHxrKAEswNg5Nex3sVe
# KOBX access gates (scanner daily limit tiers)
ENIGMA_KOBX_REQUIRED_BALANCE=500000
ENIGMA_KOBX_HIGH_TIER_BALANCE=3000000
ENIGMA_KOBX_GATING_ENABLED=0
# Premium tier amounts (lamports)
ENIGMA_PRO1_LAMPORTS=500000000
ENIGMA_PRO2_LAMPORTS=2500000000
ENIGMA_PRO3_LAMPORTS=5000000000
ENIGMA_PRO4_LAMPORTS=25000000000

# Live execution
# Keep disabled for first release. These values are for controlled operator environments only.
ENIGMA_PAPER_ONLY_MODE=1
ENIGMA_EXECUTION_ENABLED=0
ENIGMA_REQUIRE_INTERNAL_LIVE_WALLET=1
ENIGMA_INTERNAL_LIVE_WALLETS=
ENIGMA_REQUIRE_PER_WALLET_SIGNER=1
ENIGMA_TRADER_WALLET_KEYS_JSON={}
ENIGMA_TRADER_PRIVATE_KEY=
ENIGMA_TRADER_PRIVATE_KEY_JSON=
ENIGMA_ALLOW_FREE_LIVE=0
ENIGMA_GLOBAL_EMERGENCY_HALT=0
ENIGMA_LIVE_CONSENT_VERSION=v1

# Paper / execution safety controls
ENIGMA_USER_EXECUTION_LOCK_TTL_MS=45000
ENIGMA_SAFETY_MAX_TOTAL_EXPOSURE_USD=500
ENIGMA_SAFETY_MAX_DAILY_LOSS_USD=100
ENIGMA_SAFETY_MAX_HOURLY_LOSS_USD=35
ENIGMA_SAFETY_MAX_TOKEN_DAILY_LOSS_USD=20
ENIGMA_SAFETY_MAX_TOKEN_HOURLY_LOSS_USD=8
ENIGMA_SAFETY_MAX_LOSS_PER_TRADE_USD=2.5
ENIGMA_SAFETY_LOSS_STREAK_THRESHOLD=3
ENIGMA_SAFETY_LOSS_STREAK_PAUSE_SEC=600
ENIGMA_SAFETY_EXIT_ON_HOSTILE_REGIME=1
ENIGMA_SAFETY_ERROR_THRESHOLD=3
ENIGMA_SAFETY_ERROR_WINDOW_SEC=600
ENIGMA_SAFETY_PAUSE_SEC=300
ENIGMA_SAFETY_MAX_DRAWDOWN_PCT=20
ENIGMA_SAFETY_DRAWDOWN_PAUSE_SEC=3600

# Optional operator alerting webhook (for live incident notifications)
ENIGMA_OPS_ALERT_WEBHOOK_URL=
ENIGMA_OPS_ALERT_MIN_LEVEL=warn
ENIGMA_OPS_ALERT_COOLDOWN_SEC=30

# Adaptive entry/exit controls
ENIGMA_ENTRY_TIMEOUT_SEC=90
ENIGMA_ENTRY_TIMEOUT_MIN_SEC=15
ENIGMA_ENTRY_TIMEOUT_MAX_SEC=90
ENIGMA_ENTRY_FALLBACK_MIN_CONFIDENCE=0.35
ENIGMA_ENTRY_FALLBACK_CONFIDENCE_DECAY=0.05
ENIGMA_ENTRY_FALLBACK_CONFIDENCE_FLOOR=0.25
ENIGMA_ENTRY_FALLBACK_SIZE_MULTIPLIER=0.5
ENIGMA_ENTRY_FALLBACK_SIZE_STEP=0.1
ENIGMA_ENTRY_FALLBACK_SIZE_MAX=0.9
ENIGMA_ENTRY_BREAKOUT_5M_PCT=0.9
ENIGMA_BREAKEVEN_TRIGGER_PCT=1.2
ENIGMA_BREAKEVEN_LOCK_PCT=0.15

# Caches and retention
ENIGMA_CANDLE_CACHE_TTL_SEC=60
ENIGMA_MARKET_REGIME_CACHE_TTL_SEC=45
ENIGMA_AUTOTRADE_RUN_RETENTION=120
ENIGMA_AUTOTRADE_EVENT_RETENTION=5000

# Optional: Jupiter buy input mint override (defaults to SOL)
ENIGMA_BUY_INPUT_MINT=So11111111111111111111111111111111111111112
